# Kconfig fragment layered on top of Alpine's config-lts.riscv64.
# Applied via `scripts/kconfig/merge_config.sh alpine.config scev.config`
# during build-kernel.sh.
#
# Only additions / overrides of RVVM-specific drivers. Everything else is
# inherited from Alpine, so the resulting kernel stays binary-compatible
# with Alpine's linux-lts userspace (initramfs scripts, mkinitfs features,
# modloop layout, etc.) and plays nicely with `apk upgrade`.

# -- I²C bus controller -------------------------------------------------
# RVVM exposes its I²C bus via an OpenCores-compatible controller (see
# RVVM's src/devices/i2c-oc.c). Alpine's stock config doesn't include this
# driver at all — not even as a module — which is the single biggest
# blocker for running Alpine on our hardware: without it the bus never
# enumerates, and everything that hangs off it (the HID keyboard/mouse)
# stays invisible.
#
# Built-in (=y) rather than =m: if modloop fails to mount for any reason
# (missing sig key, wrong path, modloop service not rc_add'd), a module
# here would mean the player can't type into the guest at all. Keyboard
# + mouse are the absolute minimum for the VM to be usable, so we pay
# the ~small-KB Image size penalty and guarantee input works on a bare
# kernel boot — even before any userspace gets a chance to mount things.
CONFIG_I2C_OCORES=y

# -- HID + I²C-HID + DT binding -----------------------------------------
# Alpine's stock config sets `CONFIG_HID=m` (the whole HID subsystem as a
# module) with `CONFIG_I2C_HID=m` and `CONFIG_HID_GENERIC=m` beneath it.
# Trying to override ONLY the child drivers to =y fails silently: the
# `make olddefconfig` pass runs dependency propagation, sees that
# HID_GENERIC depends on HID (which is still =m), and demotes
# HID_GENERIC back to =m. The override is effectively ignored.
#
# Fix: pin the ENTIRE HID tree built-in. Keyboard + mouse input go
# through this chain on our hardware and nothing else needs to load
# modules for it, so we pay the ~small-KB Image cost once and escape the
# depmod / modprobe dance entirely.
#
# CONFIG_HID=y           — HID subsystem core
# CONFIG_HID_GENERIC=y   — HID report parser → input events
# CONFIG_I2C_HID=y       — HID-over-I²C transport
# CONFIG_I2C_HID_CORE=y  — actual driver (I2C_HID is a menu option in newer Linux)
# CONFIG_I2C_HID_OF=y    — device-tree binding (matches RVVM's `hid-over-i2c` node)
CONFIG_HID=y
CONFIG_HID_GENERIC=y
CONFIG_I2C_HID=y
CONFIG_I2C_HID_CORE=y
CONFIG_I2C_HID_OF=y

# -- Fixed-voltage regulator built-in -------------------------------------
# THIS IS WHY THE HID KEYBOARD SILENTLY FAILS TO WORK on Alpine even with
# the full HID tree pinned built-in. RVVM's DTB declares the HID children
# with `vdd-supply` / `vddl-supply` pointing at a `regulator-fixed` node
# (dummy power rail, see rvvm/src/devices/i2c-hid.c). Linux's
# `drivers/hid/i2c-hid/i2c-hid-of.c` probe path:
#
#     ihid_of->supplies[0].supply = "vdd";
#     ihid_of->supplies[1].supply = "vddl";
#     ret = devm_regulator_bulk_get(...);
#     if (ret) return ret;
#
# With `CONFIG_REGULATOR_FIXED_VOLTAGE=m` (Alpine's default), the
# regulator-fixed driver isn't bound to the DT node at kernel init time
# — so `devm_regulator_bulk_get` returns `-EPROBE_DEFER`, i2c-hid-of's
# probe gets deferred, and the deferral is only retried if the regulator
# module is ever loaded. In Alpine's sys-install mdev DOES modprobe on
# hotplug, but by the time that fires there's no further probe trigger
# for the deferred i2c-hid-of, so the HID device never enumerates.
# User types on the Tinkerpad screen → nothing happens. Classic three-
# rebuild-cycle dead-end if you only pin the HID tree and don't follow
# the dependency chain all the way down.
#
# Built-in (=y): the fixed-voltage regulator binds at kernel init before
# i2c-hid-of probes, the supply lookup succeeds, i2c-hid-of attaches the
# device to the input layer, and typing reaches the shell.
CONFIG_REGULATOR_FIXED_VOLTAGE=y

# -- Realtek 8169 NIC built-in --------------------------------------------
# RVVM's network card is a Realtek RTL8169 (see rvvm/src/devices/rtl8169.c).
# Alpine ships the driver as `CONFIG_R8169=m`. Module autoloading on the
# scev sys-install path was unreliable (mdev's hotplug handler calls
# modprobe, but cross-arch depmod in the build pipeline didn't generate
# `modules.dep` / `modules.alias` — so modprobe fails silently on a
# fresh boot and eth0 never enumerates). We fix depmod in
# `tools/build-nvme-sysinstall.sh`, but for the primary NIC we also
# build it in so the interface is guaranteed present from kernel init —
# no modprobe required, no race with `networking` OpenRC service, works
# on the very first boot before `mkinitfs` has a chance to re-pack.
#
# Observable symptom of this regressing: `ping 8.8.8.8` prints "Network
# unreachable" because the routing table has no default route (because
# eth0 never came up, because the driver never loaded).
CONFIG_R8169=y

# -- Uncompressed kernel modules -----------------------------------------
# Alpine's stock config has `CONFIG_MODULE_COMPRESS_GZIP=y` so every .ko
# is shipped as .ko.gz. That's fine at runtime — Alpine's kmod is built
# with zlib support — but blows up our build pipeline: Debian trixie's
# kmod (in the builder Dockerfile) is configured `+ZSTD +XZ -ZLIB`, so
# `make modules_install` AND our own `depmod -b` both silently skip
# every .ko.gz file and produce a 0-byte `modules.dep` / near-empty
# `modules.alias`. `mdev`'s hotplug modprobe rule then has no index to
# consult and fails to load any module on demand (the symptom that
# almost masked the R8169 issue — even after fixing the NIC, other
# modules like SND_HDA / GPIO_SIFIVE / 9P would stay unloaded).
#
# Shipping modules uncompressed is a ~20 MiB rootfs-size hit across the
# 830-odd .ko files, well inside the per-disk capacity we advertise.
# The alternative (rebuilding kmod with zlib in the Dockerfile) would
# work too, but this approach is one line in the config fragment and
# makes the build pipeline independent of the host's libz state.
# CONFIG_MODULE_COMPRESS_GZIP is not set
# CONFIG_MODULE_COMPRESS_XZ is not set
# CONFIG_MODULE_COMPRESS_ZSTD is not set
# CONFIG_MODULE_COMPRESS_ALL is not set
# CONFIG_MODULE_COMPRESS is not set
CONFIG_MODULE_COMPRESS_NONE=y

# -- HDA audio ----------------------------------------------------------
# RVVM's sound-hda.c emulates an Intel HDA controller with a C-Media CM8888
# codec. Alpine disables SND_HDA_INTEL entirely on riscv64 (no audio in
# qemu-virt's config either). Re-enable both the controller and the
# generic codec parser that handles CM8888's Audio Output widget graph.
CONFIG_SND_HDA_INTEL=m
CONFIG_SND_HDA_GENERIC=m
CONFIG_SND_HDA_CODEC_CMEDIA=m
# Beep Generator widget (NID 4 in our codec). Without this option the
# kernel sees the widget — codec dump shows "Node 0x04 [Beep Generator
# Widget]" — but doesn't create the input-event device or "Beep Playback
# Volume" / "Beep Playback Switch" mixer controls, so neither `beep` nor
# direct `EV_SND` writes can reach it.
CONFIG_SND_HDA_INPUT_BEEP=y

# -- PCI parallel port --------------------------------------------------
# RVVM's parport-pci.c emulates a NetMos / MosChip MCS9900 single-port
# PCI parport (vendor 0x9710 device 0x9900). Linux's parport_pc.c picks
# it up via PCI ID and exposes /dev/parport0 + /dev/lp0. Alpine's stock
# riscv64 kernel disables parport entirely; re-enable so guests can
# print to the emulator's host-side file backend (default
# /tmp/rvvm-parport0.out), use ppdev for raw bit-banging, or run PLIP
# between two RVVM instances connected by a virtual parallel cable.
CONFIG_PARPORT=m
CONFIG_PARPORT_PC=m
CONFIG_PARPORT_1284=y
CONFIG_PARPORT_PC_FIFO=y    # ECP fifo paths (no harm if unused)
CONFIG_PRINTER=m            # /dev/lp0 line printer abstraction
CONFIG_PPDEV=m              # /dev/parport0 raw access for bit-bang use
CONFIG_PLIP=m               # IP over parallel cable

# -- SiFive GPIO --------------------------------------------------------
# RVVM's MCU tier exposes a SiFive-flavoured GPIO controller for the
# ComputerCase's "FRONT" pin (drives in-world redstone). Alpine disables
# GPIO_SIFIVE; re-enable for the MCU + blinky pathway to work.
CONFIG_GPIO_SIFIVE=m

# -- Framebuffer ---------------------------------------------------------
# Alpine's kernel uses DRM simpledrm (CONFIG_DRM_SIMPLEDRM=y) instead of
# the old fbdev CONFIG_FB_SIMPLE path. Both read the same
# `simple-framebuffer` DT node, so Alpine's default should cover RVVM's
# framebuffer without changes. Pin the assumption here so we notice if
# Alpine ever flips it off.
CONFIG_DRM_SIMPLEDRM=y

# -- Plan 9 filesystem (9P) ----------------------------------------------
# Enables host↔guest directory sharing. Three transports:
#
#   _VIRTIO: rides on virtio-pci — the fast path, but needs virtio in
#            the host emulator. RVVM doesn't expose virtio today, so
#            this is aspirational (harmless to build as =m).
#   _FD:     transport over any file descriptor — a UART, a pipe, a
#            Unix socket. Usable today: pair with a scev-side 9P
#            server over ttyS2 (or similar) and the guest can mount
#            a host directory with `mount -t 9p -o trans=fd,...`.
#   _FS:     the filesystem layer that sits on top of whichever
#            transport is active.
#
# All three as modules so we don't inflate the kernel Image for a
# feature the host side may not wire up on every machine.
CONFIG_NET_9P=m
CONFIG_NET_9P_VIRTIO=m
CONFIG_NET_9P_FD=m
CONFIG_9P_FS=m
CONFIG_9P_FS_POSIX_ACL=y
CONFIG_9P_FS_SECURITY=y

# -- Boot-critical filesystems built-in -----------------------------------
# Alpine's stock kernel has these as modules living inside the initramfs
# (ext4.ko, squashfs.ko, overlay.ko). When we rebuild the kernel from the
# same source but a different toolchain/host, our modules get a different
# `vermagic` string, so modprobe inside Alpine's stock initramfs refuses
# to load them — and the boot media (ext4) can never be mounted.
# Force them built-in to break the version-mismatch dependency entirely.
CONFIG_EXT4_FS=y
CONFIG_SQUASHFS=y           # modloop is squashfs
CONFIG_OVERLAY_FS=y         # Alpine tmpfs-over-modloop root
CONFIG_F2FS_FS=y            # harmless; matches Alpine default
CONFIG_BLK_DEV_LOOP=y       # mounting modloop-lts as a block device
# Alpine's initramfs is keyed to Alpine's build-host vermagic, so
# modprobe inside the initramfs can't find /lib/modules/$(uname -r)/.
# Anything needed BEFORE modloop mounts therefore has to be built-in.
# After modloop mounts, /lib/modules/<our-ver>/ appears (packed by
# scev-alpine's build-modloop.sh from our kernel's modules_install
# tree), and subsequent modprobes work normally.

# -- NVMe block driver built-in -------------------------------------------
# The scev mod's preloaded Alpine image is a sys-install: pid 1 lives on
# /dev/nvme0n1p1, not a tmpfs overlay (see the mod's assembleAlpineImage
# task). For the kernel to mount its own root at boot without relying on
# an initramfs, the NVMe driver must be compiled in — same reason ext4 is
# built-in above. Without this, `root=/dev/nvme0n1p1` on the cmdline is
# seen before the driver exists and the kernel panics at "unable to mount
# root fs". Alpine's stock kernel has these as modules.
CONFIG_NVME_CORE=y
CONFIG_BLK_DEV_NVME=y

# -- evdev built-in -------------------------------------------------------
# In Alpine's live image, modloop + depmod let mdev autoload evdev when
# the input devices enumerate. The scev sys-install ships modules on the
# rootfs but doesn't pre-run depmod (apk.static can't cross-execute the
# target's depmod from the build host), so mdev's modprobe has no
# modules.dep to read. Without evdev, no `/dev/input/event*` nodes, no
# userspace view of keyboard events.
#
# (HID_GENERIC is pinned built-in above as part of the HID tree override.)
CONFIG_INPUT_EVDEV=y

# -- Goldfish RTC built-in ------------------------------------------------
# RVVM emulates a Goldfish-spec RTC at MMIO; Alpine's stock config ships
# the driver as CONFIG_RTC_DRV_GOLDFISH=m. In a live image, modloop plus
# depmod let mdev autoload it when /sys/devices/platform/.../rtc appears.
# On the scev sys-install path modules exist on the rootfs but no one
# runs depmod cross-arch during the bootstrap, so mdev's modprobe no-ops
# silently. Result: /dev/rtc0 never appears, OpenRC's hwclock service
# prints "Failed to set system clock" on boot, and the Alpine system
# clock free-runs from the kernel's jiffy counter until network NTP
# catches up (or forever, if the VM has no network).
#
# Built-in makes the driver load during kernel init alongside the other
# MMIO devices, /dev/rtc0 shows up before userspace starts, hwclock
# works, boot stays quiet.
CONFIG_RTC_DRV_GOLDFISH=y

# -- Console font ---------------------------------------------------------
# Alpine disables FONT_8x16 and keeps FONT_TER16x32 (high-dpi Terminus).
# simpledrm's default-font picker then lands on 16x32 for our 640x480
# framebuffer, giving a 40x15 console (huge chars). Re-enable the classic
# 8x16 font so fbcon picks that for sub-1024-wide displays.
CONFIG_FONT_8x16=y
